---
import "../styles/base.css";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

export interface Props {
  title: string;
  description: string;
  /** Chemin d'image OG absolu ou relatif à la racine du site. */
  ogImage?: string;
  /** Type de page Open Graph. Défaut : website. */
  ogType?: "website" | "article";
  /** Indique si la page est une page d'article (active les meta article). */
  publishedTime?: string;
  modifiedTime?: string;
  /** Désactiver l'indexation (pages de test, légales transitoires). */
  noindex?: boolean;
  /** Classes additionnelles sur le <main>. */
  mainClass?: string;
}

const {
  title,
  description,
  ogImage = "/og-default.png",
  ogType = "website",
  publishedTime,
  modifiedTime,
  noindex = false,
  mainClass = "",
} = Astro.props;

const fullTitle =
  title === "Horizon Immobilier"
    ? title
    : `${title} — Horizon Immobilier`;
---

<!doctype html>
<html lang="fr">
  <head>
    <BaseHead
      title={fullTitle}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      noindex={noindex}
    />
  </head>
  <body>
    <a href="#contenu" class="visually-hidden">Aller au contenu</a>
    <Header />
    <main id="contenu" class={mainClass}>
      <slot />
    </main>
    <Footer />
  </body>
</html>
