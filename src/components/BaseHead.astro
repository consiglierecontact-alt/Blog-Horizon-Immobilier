---
import "@fontsource-variable/fraunces";
import "@fontsource-variable/inter";
import "@fontsource/jetbrains-mono/400.css";
import "@fontsource/jetbrains-mono/500.css";

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  ogImage = "/og-default.png",
  ogType = "website",
  publishedTime,
  modifiedTime,
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);

// Données structurées Organization — servent à Google pour le knowledge panel.
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Horizon Immobilier",
  description:
    "Cabinet de conseil en investissement immobilier. Stratégie patrimoniale, optimisation fiscale, sélection de biens pour investisseurs.",
  url: Astro.site?.toString() ?? "",
  logo: new URL("/favicon.svg", Astro.site).toString(),
  sameAs: [
    // À compléter quand les réseaux sociaux pro seront en ligne.
  ],
};
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />

{
  noindex ? (
    <meta name="robots" content="noindex, nofollow" />
  ) : (
    <meta name="robots" content="index, follow" />
  )
}

{/* Open Graph */}
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content="Horizon Immobilier" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:locale" content="fr_FR" />

{/* Twitter */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />

{
  publishedTime && (
    <meta property="article:published_time" content={publishedTime} />
  )
}
{modifiedTime && (
  <meta property="article:modified_time" content={modifiedTime} />
)}

{/* Fonts preload — variables chargées en une seule ressource par famille */}
<link
  rel="preconnect"
  href="https://fonts.gstatic.com"
  crossorigin
/>

{/* Sitemap découverte */}
<link rel="sitemap" href="/sitemap-index.xml" />
<link
  rel="alternate"
  type="application/rss+xml"
  title="Horizon Immobilier — Analyses"
  href="/rss.xml"
/>

<script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
