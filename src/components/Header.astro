---
import { CATEGORIES } from "../data/categories";

const currentPath = Astro.url.pathname;

// Liens principaux — "Analyses" pointe vers le blog.
const navLinks = [
  { href: "/blog", label: "Analyses" },
  { href: "/services", label: "Services" },
  { href: "/a-propos", label: "À propos" },
  { href: "/contact", label: "Contact" },
];

function isActive(href: string): boolean {
  if (href === "/") return currentPath === "/";
  return currentPath === href || currentPath.startsWith(href + "/");
}
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo" aria-label="Horizon Immobilier — accueil">
      <span class="logo-mark" aria-hidden="true">
        <img src="/logo.png" alt="Logo Horizon Immobilier" style="height: 32px; width: auto; display: block;" />
      </span>
      <span class="logo-text">Horizon Immobilier</span>
    </a>

    <nav class="nav-desktop" aria-label="Navigation principale">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={["nav-link", { "is-active": isActive(link.href) }]}
            aria-current={isActive(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="header-cta">
      <a href="https://calendly.com/immo-scopie/30min" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Réserver un appel gratuit</a>
    </div>

    <button
      type="button"
      class="nav-toggle"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-mobile-toggle
    >
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>
  </div>

  <div id="mobile-menu" class="mobile-menu" data-mobile-menu hidden>
    <nav class="mobile-nav" aria-label="Navigation mobile">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={["mobile-link", { "is-active": isActive(link.href) }]}
          >
            {link.label}
          </a>
        ))
      }
      <a href="https://calendly.com/immo-scopie/30min" target="_blank" rel="noopener noreferrer" class="btn btn-primary mobile-cta">Réserver un appel gratuit</a>
      <div class="mobile-categories">
        <p class="eyebrow">Catégories</p>
        <ul>
          {
            CATEGORIES.map((cat) => (
              <li>
                <a href={`/blog/categorie/${cat.slug}`}>{cat.label}</a>
              </li>
            ))
          }
        </ul>
      </div>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-header);
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-rule);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    height: 72px;
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
    color: var(--color-ink);
  }

  .logo-mark {
    display: inline-flex;
    flex-shrink: 0;
  }

  .logo-text {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: var(--weight-medium);
    letter-spacing: -0.01em;
  }

  .nav-desktop {
    display: flex;
    align-items: center;
    gap: var(--space-2xl);
    margin-left: auto;
  }

  .nav-link {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: var(--weight-semibold);
    color: var(--color-ink);
    text-decoration: none;
    padding: 4px 0 8px;
    border-bottom: 2px solid transparent;
    transition: color var(--duration-base) var(--ease-out),
      border-color var(--duration-base) var(--ease-out);
  }

  .nav-link:hover {
    color: var(--color-primary);
    text-decoration: none;
  }

  .nav-link.is-active {
    color: var(--color-primary);
    border-bottom-color: var(--color-accent);
  }

  .header-cta {
    margin-left: var(--space-md);
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 4px;
    padding: 8px;
    margin-left: auto;
  }

  .nav-toggle-bar {
    display: block;
    width: 22px;
    height: 1.5px;
    background-color: var(--color-ink);
    transition: transform var(--duration-base) var(--ease-out),
      opacity var(--duration-base) var(--ease-out);
  }

  .mobile-menu {
    display: none;
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-rule);
  }

  .mobile-menu[hidden] {
    display: none !important;
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding: var(--space-lg) var(--gutter) var(--space-2xl);
  }

  .mobile-link {
    font-family: var(--font-display);
    font-size: var(--text-headline);
    line-height: 1.15;
    color: var(--color-ink);
    text-decoration: none;
  }

  .mobile-link.is-active {
    color: var(--color-primary);
  }

  .mobile-cta {
    margin-top: var(--space-sm);
    align-self: flex-start;
  }

  .mobile-categories {
    margin-top: var(--space-lg);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-rule);
  }

  .mobile-categories ul {
    list-style: none;
    padding: 0;
    margin: var(--space-sm) 0 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xs);
  }

  .mobile-categories a {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-muted);
    text-decoration: none;
  }

  .mobile-categories a:hover {
    color: var(--color-primary);
  }

  @media (max-width: 900px) {
    .nav-desktop,
    .header-cta {
      display: none;
    }
    .nav-toggle {
      display: flex;
    }
    .mobile-menu[data-open] {
      display: block;
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-mobile-toggle]");
  const menu = document.querySelector<HTMLElement>("[data-mobile-menu]");

  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      if (isOpen) {
        toggle.setAttribute("aria-expanded", "false");
        toggle.setAttribute("aria-label", "Ouvrir le menu");
        menu.removeAttribute("data-open");
        menu.setAttribute("hidden", "");
      } else {
        toggle.setAttribute("aria-expanded", "true");
        toggle.setAttribute("aria-label", "Fermer le menu");
        menu.setAttribute("data-open", "");
        menu.removeAttribute("hidden");
      }
    });
  }
</script>
