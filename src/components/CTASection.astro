---
export interface Props {
  /** Titre du bloc. */
  title?: string;
  /** Sous-titre / explication. */
  subtitle?: string;
  /**Variation visuelle : sombre (par défaut) ou claire. */
  variant?: "deep" | "light";
}

const {
  title = "Un projet d'investissement ? Parlons-en.",
  subtitle = "Trente minutes pour faire le point sur votre situation et vos objectifs. Sans engagement, sans argumentaire commercial — juste un échange d'expertise.",
  variant = "deep",
} = Astro.props;
---

<section class:list={["cta-section", `cta-section--${variant}`]}>
  <div class="container cta-inner">
    <div class="cta-text">
      <h2 class="cta-title">{title}</h2>
      <p class="cta-subtitle">{subtitle}</p>
    </div>
    <div class="cta-actions">
      <a href="https://calendly.com/immo-scopie/30min" target="_blank" rel="noopener noreferrer" class="btn btn-accent">Réserver un appel gratuit</a>
      <a href="/estimation" class="cta-link">Ou demander une estimation gratuite →</a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding-block: var(--space-4xl);
  }

  .cta-section--deep {
    background-color: var(--color-primary-deep);
    color: var(--color-on-primary);
  }

  .cta-section--light {
    background-color: var(--color-surface);
    color: var(--color-ink);
  }

  .cta-inner {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
  }

  .cta-title {
    font-family: var(--font-display);
    font-size: var(--text-headline);
    line-height: var(--text-headline-lh);
    letter-spacing: var(--text-headline-ls);
    margin: 0 0 var(--space-md);
    color: inherit;
  }

  .cta-section--deep .cta-title {
    color: var(--color-bg);
  }

  .cta-subtitle {
    font-size: var(--text-body);
    line-height: var(--text-body-lh);
    max-width: 52ch;
    margin: 0;
    color: oklch(0.85 0.02 250);
  }

  .cta-section--light .cta-subtitle {
    color: var(--color-muted);
  }

  .cta-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .cta-actions .btn {
    align-self: stretch;
    text-align: center;
  }

  .cta-link {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-accent);
    text-decoration: none;
    transition: color var(--duration-base) var(--ease-out);
  }

  .cta-section--light .cta-link {
    color: var(--color-primary);
  }

  .cta-link:hover {
    color: var(--color-bg);
    text-decoration: none;
  }

  .cta-section--light .cta-link:hover {
    color: var(--color-primary-deep);
  }

  @media (max-width: 768px) {
    .cta-inner {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
    .cta-actions {
      align-items: stretch;
    }
  }
</style>
